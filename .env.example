## Application Configuration
## Copy this file to .env and fill in your values

# ============================================================
# SERVER
# ============================================================
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# ============================================================
# DATABASE (PostgreSQL / Supabase)
# ============================================================
DB_URL=jdbc:postgresql://your_db_host:5432/postgres
DB_PASSWORD=your_db_password

# For Supabase, use:
# DB_URL=jdbc:postgresql://postgres.iutzqiznoulxxeciaolb:Prajjwal@2003@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# DB_USERNAME=postgres
# DB_PASSWORD=your_supabase_password

# ============================================================
# GOOGLE OAUTH2
# Create project at https://console.cloud.google.com
# Enable Gmail API + Google Calendar API
# Create OAuth 2.0 Credentials (Web Application)
# Add redirect URI: http://localhost:8080/login/oauth2/code/google
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

#For ios
GOOGLE_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
# ============================================================
# JWT
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long
JWT_EXPIRATION_MS=86400000

# ============================================================
# ENCRYPTION (AES-256 for storing Gmail tokens)
# Must be exactly 32 characters
# ============================================================
ENCRYPTION_KEY=your_encryption_key_exactly_32_chars

# ============================================================
# AI - GROQ API (Primary)
# Free at: https://console.groq.com
# ============================================================
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192

# ============================================================
# AI - OPENROUTER API (Fallback)
# Free at: https://openrouter.ai
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
# ============================================================
# FIREBASE CLOUD MESSAGING (FCM)
# Get service account JSON from Firebase Console
# ============================================================
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
# OR paste the JSON content as a Base64 encoded string:
FIREBASE_SERVICE_ACCOUNT_

# ============================================================
# EMAIL NOTIFICATIONS (Admin alerts)
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
ADMIN_EMAIL=admin@notivio.com

# ============================================================
# KEEP-ALIVE (Prevent free tier sleeping)
# ============================================================
KEEPALIVE_URL=http://localhost:8080/health
KEEPALIVE_INTERVAL_MINUTES=5

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================
# GMAIL SYNC
# ============================================================
GMAIL_SYNC_INTERVAL_MINUTES=15
GMAIL_MAX_EMAILS_PER_SYNC=50

# ============================================================
# SCHEDULER
# ============================================================
REMINDER_CHECK_INTERVAL_SECONDS=60
TASK_STATUS_UPDATE_INTERVAL_HOURS=1

# ============================================================
# FRONTEND URL (for CORS and OAuth redirect)
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# ACTIVE PROFILE
# ============================================================
SPRING_PROFILES_ACTIVE=dev
